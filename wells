#!/usr/bin/env bash
# Wells launcher — runs the harness from the cloned repo, no install needed.
#
# Usage:
#   ./wells "<your goal>"                 # run on this repo
#   ./wells --workspace /path "fix bug"   # run against another project
#   ./wells config                        # interactive settings menu
#   ./wells info                          # show configuration
#
# This wrapper handles the venv automatically. It deliberately AVOIDS building
# the local package (which would need hatchling from PyPI) by running the
# harness module directly with PYTHONPATH=src. It also tells uv to use the
# system certificate store (UV_SYSTEM_CERTS, or UV_NATIVE_TLS on older uv) —
# needed on corporate networks whose proxy presents a self-signed cert that
# Python's bundled certifi rejects.

set -e

# Resolve the directory this script lives in (the repo root), independent of CWD.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Use the OS certificate store so corporate TLS-intercepting proxies work.
# Newer uv renamed UV_NATIVE_TLS to UV_SYSTEM_CERTS (the old name still works
# but prints a deprecation warning) — set whichever this uv understands.
if [ -z "${UV_SYSTEM_CERTS:-}" ] && [ -z "${UV_NATIVE_TLS:-}" ]; then
    if uv sync --help 2>/dev/null | grep -q "UV_SYSTEM_CERTS"; then
        export UV_SYSTEM_CERTS=1
    else
        export UV_NATIVE_TLS=1
    fi
fi

# Sync dependencies WITHOUT building the local package. --no-install-project
# means uv never invokes the build backend (hatchling), so no PyPI fetch is
# needed for the build step. Deps are pre-built wheels.
if ! uv sync --no-install-project --quiet 2>/dev/null; then
    echo "[wells] installing dependencies (first run may take a minute) ..."
    uv sync --no-install-project || {
        echo "[wells] dependency install failed. Check your network/TLS settings." >&2
        echo "[wells] If behind a proxy, try: set SSL_CERT_FILE= and REQUESTS_CA_BUNDLE=" >&2
        exit 1
    }
fi

# Run the harness directly from src/ — no package build, no install step.
export PYTHONPATH="$SCRIPT_DIR/src${PYTHONPATH:+:$PYTHONPATH}"
exec uv run python -m wells.main "$@"
