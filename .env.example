# Wells harness — example configuration.
# Copy to .env and edit. Or run `wells config` for an interactive menu.

# ===========================================================================
# Provider profiles (model-agnostic core)
# ===========================================================================
# A *profile* is a named bundle of (provider kind, model, api key, base url).
# Configure each profile with MODEL_<name> / API_KEY_<name> / BASE_URL_<name>.

# Which profiles are configured (comma-separated) and which is active.
MODEL_PROFILES=zai
MODEL_PROFILE=zai
# Optional: cheaper model for low-stakes subtasks (summarize/compress/etc).
# MODEL_PROFILE_CHEAP=zai

# --- Built-in `zai` profile (Z.ai GLM, OpenAI-compatible) ------------------
# Uses the CODING endpoint (/api/coding/paas/v4/) required by GLM-4.x/5.x.
# NOTE: legacy ZAI_* vars below ALSO work and seed this same profile; explicit
# MODEL_zai / BASE_URL_zai / API_KEY_zai take precedence when both are set.
MODEL_zai=glm-5.2
API_KEY_zai=your-zai-api-key-here
BASE_URL_zai=https://api.z.ai/api/coding/paas/v4/

# --- Example: add more profiles (uncomment + edit) -------------------------
# Google Gemini (requires: pip install langchain-google-genai):
# MODEL_gemini=gemini-2.0-flash
# API_KEY_gemini=your-gemini-api-key
#
# OpenAI direct:
# MODEL_OPENAI=gpt-5o-mini
# API_KEY_OPENAI=sk-...
#
# OpenRouter (hundreds of models via one key):
# MODEL_openrouter=anthropic/claude-sonnet-4-5
# API_KEY_openrouter=sk-or-...
#
# Anthropic direct (requires: pip install langchain-anthropic):
# MODEL_anthropic=claude-sonnet-4-5
# API_KEY_anthropic=sk-ant-...
#
# Local Ollama (requires: pip install langchain-ollama):
# MODEL_ollama=devstral
# BASE_URL_ollama=http://localhost:11434
#
# Any OpenAI-compatible local endpoint (vLLM, LM Studio, etc.):
# MODEL_local=my-finetune
# BASE_URL_local=http://localhost:8000/v1

# ===========================================================================
# Legacy Z.ai variables (still supported — seeds the `zai` profile)
# ===========================================================================
# ZAI_API_KEY=your-zai-api-key-here
# ZAI_ENDPOINT=https://api.z.ai/api/coding/paas/v4/
# ZAI_MODEL=glm-5.2
# ZAI_MODEL_CHEAP=

# ===========================================================================
# Workspace + safety
# ===========================================================================
# Directory the agent is confined to (path escapes are blocked).
# Defaults to the current working directory.
# WORKSPACE_ROOT=/path/to/your/project

# Safety policy for writes/shell: auto | approve | dryrun
#   auto    - execute immediately (confined to WORKSPACE_ROOT)
#   approve - require an approval callback (dry-run if none wired)
#   dryrun  - never execute; describe what would happen
HARNESS_SAFETY=auto

# Plan mode: coder plans edits without applying them (review-first workflow).
PLAN_MODE=0

# ===========================================================================
# Run behaviour
# ===========================================================================
# Max coder <-> tester <-> reviewer loop iterations.
MAX_ITERATIONS=3
# Max tool-call rounds in a single agentic executor run.
MAX_TOOL_STEPS=25
# Max seconds for a single shell command.
SHELL_TIMEOUT=120
# When 1, the finisher pushes the branch and opens a PR via `gh` after a run.
WELLS_OPEN_PR=0

# ===========================================================================
# Token optimization
# ===========================================================================
TOKEN_BUDGET_MAX_INPUT=24000
TOKEN_BUDGET_SMALL_INPUT=8000
TOKEN_BUDGET_RESERVED_OUTPUT=4000
# Replace verbatim plan/architecture with a summary on loop iterations once the
# durable context exceeds this many tokens. Set 0 or SUMMARIZE_ON_LOOP=false
# to disable (keeps full context verbatim every iteration).
SUMMARIZE_ON_LOOP=1
SUMMARIZE_THRESHOLD=1500

# ===========================================================================
# LLM tuning
# ===========================================================================
LLM_TIMEOUT=180
LLM_MAX_RETRIES=5
LLM_BACKOFF_BASE=2.0

# ===========================================================================
# Command screening (optional)
# ===========================================================================
# |-separated regex patterns always refused by run_command, regardless of safety.
# BLOCKED_COMMANDS=rm\s+-rf\s+/|mkfs|dd\s+if=|:\(\)\s*\{|shutdown|reboot
