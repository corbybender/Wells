# Z.ai (ZhipuAI) OpenAI-compatible API credentials.
# Get a key from https://z.ai and paste it below after copying this file to .env .

ZAI_API_KEY=your-zai-api-key-here
ZAI_ENDPOINT=https://api.z.ai/api/coding/paas/v4/
ZAI_MODEL=glm-5.1

# Optional: cheaper/faster model for low-stakes subtasks (summarization,
# log compression, classification). Routed automatically by the model router.
# Leave blank to use ZAI_MODEL for everything.
# ZAI_MODEL_CHEAP=glm-4-flash

# Maximum number of coder -> tester -> reviewer loop iterations.
MAX_ITERATIONS=3

# --- Token optimization ---------------------------------------------------
# Input budget per call (above this, low-priority context is trimmed).
TOKEN_BUDGET_MAX_INPUT=24000
TOKEN_BUDGET_SMALL_INPUT=8000
TOKEN_BUDGET_RESERVED_OUTPUT=4000
# Replace verbatim plan/architecture with a summary on loop iterations once the
# durable context exceeds this many (estimated) tokens. 0 or SUMMARIZE_ON_LOOP=false
# disables it (keeps full context verbatim every iteration).
SUMMARIZE_ON_LOOP=1
SUMMARIZE_THRESHOLD=1500
